			)
		)
		(uuid "3324012f-e8fc-43de-9075-cc32b7c7b8c1")
	)
	(text "Design from AP62300TWU-7 Datasheet.\nTable 1 contains recommended component values based on output voltage.\n"
		(exclude_from_sim no)
		(at 302.26 63.5 0)
		(effects
