	(text "12pF @ 25MHz\nCL - Cs = (CL1 * CL2) / (CL1 + CL2)\n12pF - 5pF = (CL1 * CL2) / (CL1 + CL2)\n7pF = (CL1 * CL2) / (CL1 + CL2)\n7pF = (14pF * 14pF) / (14pF + 14pF)\n7pF = 7pF \nCL1 = CL2 = 14pF = C16 = C18\n\nCalculations based off design from AN2867 Application Note."
		(exclude_from_sim no)
		(at 154.94 57.15 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "32da4498-534c-4a69-94ef-e8fb08686525")
	)
